{
  "name": "opendownloader",
  "version": "1.0.0",
  "description": "Download videos from YouTube, Instagram, Facebook, TikTok, Twitter/X, Vimeo, and Google Drive.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThiruvarankanM/OpenDownloader.git"
  },
  "bugs": {
    "url": "https://github.com/ThiruvarankanM/OpenDownloader/issues"
  },
  "homepage": "https://github.com/ThiruvarankanM/OpenDownloader#readme",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "setup:auth": "node scripts/setup-auth.js",
    "setup:ytdlp": "curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o /usr/local/bin/yt-dlp && chmod +x /usr/local/bin/yt-dlp"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.50.0",
    "zod": "^3.22.4"
  }
}
