# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Local development convenience:
# - default behavior is AUTH_BYPASS=true when NODE_ENV=development
# - always keep AUTH_BYPASS=false in production deployments
AUTH_BYPASS=false

# ── Auth ────────────────────────────────────────────────────────
# Generate a secure random JWT secret (minimum 32 characters):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-secure-random-string-minimum-32-characters

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Login credentials for the web UI
ADMIN_USERNAME=admin

# Generate a bcrypt hash for your chosen password (cost factor 12):
#   node -e "import('bcryptjs').then(b => b.default.hash('yourpassword', 12).then(console.log))"
ADMIN_PASSWORD_HASH=$2b$12$replacethiswitharealbcrypthashedpassword

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your domain in production)
ALLOWED_ORIGINS=https://yourdomain.com

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_MAX=50
DOWNLOAD_RATE_MAX=5
